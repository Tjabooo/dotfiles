{
	"layer": "top",
	"modules-left": ["custom/launcher","cpu","memory","custom/media","tray"],
	"modules-center": ["river/tags", "wlr/workspaces", "custom/clock"],
	"modules-right": ["custom/updates","backlight","pulseaudio", "custom/kbd--layout", "network", "battery"],
	
	"pulseaudio": {
		"tooltip": false,
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-muted": "{icon} {volume}%",
		"on-click":"pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"format-icons": {
			"default": ["пЂ¦", "пЂ§", "пЂЁ"]
		}
	},

    "river/tags": {
		"num-tags": 6
    },
	"network": {
		"tooltip": false,
		"format-wifi": "п‡«  {essid}",
		"format-ethernet": ""
	},
	"backlight": {
		"tooltip": false,
		"format": "пѓ« {}%",
		"interval":1,
        "on-scroll-up": "light -A 5",
		"on-scroll-down": "light -U 5"
	},
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "п‡¦ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
	"tray":{
		"icon-size":18,
		"spacing": 10
	},
  "wlr/workspaces": {
        "format": "{icon}",
        "format-active": " {icon} ",
        "on-click": "activate"
        // "format-icons":{
        //     "10":"10"
        // }
    },
    "custom/clock": {
        "exec": "date +'п—µ %D пЂ— %H:%M:%S'",
        "interval": 1
    },
    "custom/keyboard-layout": {
        "return-type": "json",
        "exec": "hypr-kbd-layout", 
        "format": "{}"
    },
    "cpu": {
        "interval": 15,
        "format": "п‹› {}%",
        "max-length": 10
    },
    "memory": {
        "interval": 30,
        "format": "пѓ‰ {}%",
        "max-length": 10
    },
    "custom/media": {
        "interval": 30,
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 20,
        "format-icons": {
            "spotify": "п†ј ",
            "default": "пў… "
        },
        "escape": true,
        "exec": "$HOME/.config/system_scripts/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause"
    },
    "custom/launcher":{
        "format": "пЊѓ ",
        "on-click": "wofi",
        "on-click-right": "killall wofi"
    },
    "custom/power":{
        "format": "п„ё ",
        "on-click": "bash ~/.config/rofi/leave/leave.sh",
    },
    "custom/updates":{
        "format": "{} Update(s)",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "alacritty -e pacman -Syu && notify-send 'The system has been updated' "
    },
    "custom/wallpaper":{
        "format":"пЂѕ ",
        "on-click": "bash ~/.config/system_scripts/pkill_bc"
    }
}
